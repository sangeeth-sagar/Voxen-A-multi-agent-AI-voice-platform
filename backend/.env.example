DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentiq
# GOOGLE_API_KEY is not used — users provide their own keys via Profile → API Keys.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GROQ_API_KEY=your-groq-api-key-from-console.groq.com

# JWT
JWT_SECRET=change-me-to-32-char-random-string-in-production
JWT_EXPIRE_MINUTES=1440

# App
APP_NAME=AgentIQ
APP_VERSION=2.4.0
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# TTS
TTS_VOICE=en-IN-NeerjaNeural
TTS_VOICE_MALE=en-IN-PrabhatNeural
WEBHOOK_BASE_URL=http://localhost:8000

# RAG / Knowledge base
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=4

# Encryption (per-user API keys at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Defaults for new agents
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_TTS_PROVIDER=elevenlabs
DEFAULT_STT_PROVIDER=groq

# Superadmin bootstrap account
ADMIN_EMAIL=admin@voxen.ai
